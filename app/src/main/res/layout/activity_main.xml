<?xml version="1.0" encoding="utf-8"?>
<!--
    Root FrameLayout: full-screen ZoomLayout (wraps the entire RecyclerView so
    pinch-to-zoom scales all PDF pages together as one document) with a floating
    toolbar overlay at the bottom.
    The toolbar auto-hides after 3 seconds of inactivity and reappears on tap.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ZoomLayout wraps the RecyclerView so the entire document zooms together -->
    <com.justpdf.ZoomLayout
        android:id="@+id/zoomLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- PDF pages rendered as a continuous vertical list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical" />

    </com.justpdf.ZoomLayout>

    <!-- Empty state: shown when no PDF is loaded -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/tap_to_open"
        android:textColor="#88FFFFFF"
        android:textSize="16sp"
        android:visibility="visible" />

    <!-- Floating toolbar overlay — anchored to the bottom, semi-transparent pill -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/toolbar_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <!-- Open file button -->
        <ImageButton
            android:id="@+id/btnOpenFile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_open_file"
            android:src="@drawable/ic_open_file"
            app:tint="@color/toolbar_icon_tint" />

        <!-- Share button -->
        <ImageButton
            android:id="@+id/btnShare"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_share"
            android:src="@drawable/ic_share"
            app:tint="@color/toolbar_icon_tint" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:background="#66FFFFFF" />

        <!-- Page counter: "3 / 12" -->
        <TextView
            android:id="@+id/tvPageCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="— / —"
            android:textColor="@color/page_counter_text"
            android:textSize="14sp" />

    </LinearLayout>

</FrameLayout>

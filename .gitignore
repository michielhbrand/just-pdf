# Android build outputs
app/build/
build/

# Gradle caches and daemon files
.gradle/

# Local Android SDK path (machine-specific)
local.properties

# IDE files
.idea/
*.iml
.DS_Store

# Signing keystores — never commit these
*.jks
*.keystore

# Zscaler / corporate proxy truststore (machine-specific, generated at build time)
# /tmp/gradle-cacerts.jks  — lives in /tmp, not in repo

# APK outputs
*.apk
*.aab
